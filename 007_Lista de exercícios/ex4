<?php
class Funcionario {
    public $nome;
    public $cargo;
    public $salario;

    public function exibir() {
        return "Nome: {$this->nome} | Cargo: {$this->cargo} | Salário: R$ " . number_format($this->salario, 2, '.', '');
    }
}

$func = new Funcionario();
$func->nome = "Rodrigo";
$func->cargo = "Desenvolvedor";
$func->salario = 4000.00;
echo $func->exibir() . "\n";
?>
