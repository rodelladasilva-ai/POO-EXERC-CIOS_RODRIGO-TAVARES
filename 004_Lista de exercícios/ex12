<?php
$valorCompra = 150.00;
$vip = true;
if ($valorCompra >= 200 || $vip) {
    $valorFinal = $valorCompra * 0.85;
} elseif ($valorCompra >= 100) {
    $valorFinal = $valorCompra * 0.90;
} else {
    $valorFinal = $valorCompra;
}
echo "Valor final: R$ " . number_format($valorFinal, 2, ',', '.');
?>
